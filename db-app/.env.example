# Google Maps JavaScript API key used by the map view.
VITE_GOOGLE_MAPS_API_KEY=

# Optional. If omitted, Ask AI uses the local deterministic planner fallback.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.5 in vite.config.ts.
OPENAI_MODEL=gpt-5.5

# Optional locally. Defaults to workspace.default.user_logs.
APP_LOG_TABLE=workspace.default.user_logs

# Required with APP_LOG_TABLE. In Databricks Apps, inject this from a SQL warehouse resource.
DATABRICKS_WAREHOUSE_ID=
